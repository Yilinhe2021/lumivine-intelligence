# Example environment variables for local development
# Copy this to .dev.vars (already in .gitignore, won't be committed) and fill in the real key
# For production, configure these in the Cloudflare dashboard — never write the real key into
# any file that gets uploaded

ANTHROPIC_API_KEY=sk-ant-fill-in-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5

# Optional: webhook that notifies the advisor team in real time once a parent leaves contact
# info (a Slack or Feishu Incoming Webhook both work, format {text: "..."})
LEAD_WEBHOOK_URL=
